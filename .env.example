# Scalekit environment URL (e.g. https://your-env.scalekit.cloud)
TOOL_ENV_URL=

# Scalekit OAuth client credentials
TOOL_CLIENT_ID=
TOOL_CLIENT_SECRET=

# Default identifier for connected accounts (e.g. your agent name or user id)
TOOL_IDENTIFIER=

# Enable debug logging to stderr (set to 1, true, or yes)
TOOL_DEBUG=
